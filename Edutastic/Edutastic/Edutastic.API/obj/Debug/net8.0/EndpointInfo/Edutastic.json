{
  "openapi": "3.0.1",
  "info": {
    "title": "Edutastic",
    "version": "1.0"
  },
  "paths": {
    "/api/Game/start": {
      "post": {
        "tags": [
          "Game"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartReq"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StartReq"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StartReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Game/{sessionId}/answer": {
      "post": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerReq"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerReq"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Game/{sessionId}/end": {
      "post": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerReq": {
        "type": "object",
        "properties": {
          "questionId": {
            "type": "integer",
            "format": "int32"
          },
          "userAnswer": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StartReq": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "moduleId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}